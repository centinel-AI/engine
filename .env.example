# Grauss engine environment template
# ENGINE_* variables for Terraform/OpenTofu, Docker engine images, and workspace tasks.
# At runtime inside containers, these are mapped to the names providers expect (ARM_*, AWS_*, …, TF_VAR_*).

# ── Engine: image / CLI versions ───────────────────────────────────────────────
# Terraform images use ENGINE_TERRAFORM_VERSION; OpenTofu images use ENGINE_OPENTOFU_VERSION (no "v" prefix).
# Optional — overrides Dockerfile default base image
ENGINE_ALPINE_VERSION=3.21.3

ENGINE_TERRAFORM_VERSION=1.15.3
ENGINE_OPENTOFU_VERSION=1.11.7

# ── Engine: provider versions (injected into ./workspace/_*.tf.json by task workspace:<cloud>; Docker build uses these as build-args) ─────────────
# Azure: AzureRM + AzureAD — registry.azuread + registry.azurerm
ENGINE_AZURERM_VERSION="=4.72.0"
ENGINE_AZUREAD_VERSION="=3.8.0"
ENGINE_GOOGLE_PROVIDER_VERSION="=7.32.0"
ENGINE_AWS_PROVIDER_VERSION="=6.44.0"
# Oracle Cloud — pin matches registry.terraform.io/providers/oracle/oci/latest
ENGINE_OCI_PROVIDER_VERSION="=8.13.0"
# OVH (OVH Public Cloud) — registry.terraform.io/providers/ovh/ovh/latest
ENGINE_OVH_PROVIDER_VERSION="=2.13.1"

# ── Engine: data project (JSON under data/<cloud>/<name>/) — Terraform var "project"
# Use project-01 for samples; on Azure use _bootstrap to provision state storage first.
ENGINE_TF_VAR_project=project-01

# ── Engine: Azure credentials (service principal) ──────────────────────────────
# Passed into containers as ARM_* (see compose.yml).
ENGINE_ARM_USE_AZUREAD=
ENGINE_ARM_CLIENT_ID=
ENGINE_ARM_CLIENT_SECRET=
ENGINE_ARM_TENANT_ID=
ENGINE_ARM_SUBSCRIPTION_ID=

# ── Engine: GCP credentials ──────────────────────────────────────────────────
# Passed into containers as GOOGLE_*.
ENGINE_GOOGLE_CREDENTIALS=
ENGINE_GOOGLE_PROJECT=
ENGINE_GOOGLE_REGION=
ENGINE_GOOGLE_ZONE=
ENGINE_GOOGLE_APPLICATION_CREDENTIALS=

# ── Engine: AWS credentials ───────────────────────────────────────────────────
# Passed into containers as AWS_*.
ENGINE_AWS_ACCESS_KEY_ID=
ENGINE_AWS_SECRET_ACCESS_KEY=
ENGINE_AWS_SESSION_TOKEN=
ENGINE_AWS_DEFAULT_REGION=
ENGINE_AWS_REGION=

# ── Engine: Oracle Cloud (OCI) credentials ────────────────────────────────────
# Passed into containers as OCI_* (see compose.yml x-env-oci).
# https://docs.oracle.com/en-us/iaas/Content/API/Concepts/apisigningkey.htm
ENGINE_OCI_CONFIG_FILE=
ENGINE_OCI_CLI_PROFILE=
ENGINE_OCI_REGION=
ENGINE_OCI_TENANCY_OCID=
ENGINE_OCI_USER_OCID=
ENGINE_OCI_FINGERPRINT=
ENGINE_OCI_PRIVATE_KEY_FILE=
ENGINE_OCI_PRIVATE_KEY_PASSWORD=
ENGINE_OCI_CLI_AUTH=

# ── Engine: OVH credentials ───────────────────────────────────────────────────
# Passed into containers as OVH_* / TF_VAR_ovh_*.
# Create API tokens at https://api.ovh.com/createToken
ENGINE_OVH_ENDPOINT=ovh-eu
ENGINE_OVH_APPLICATION_KEY=
ENGINE_OVH_APPLICATION_SECRET=
ENGINE_OVH_CONSUMER_KEY=
# OVH Cloud project ID: UUID shown in OVH Control Panel → Public Cloud → Settings (project ID).
ENGINE_OVH_SERVICE_NAME=
# OVH S3-compatible Object Storage credentials (from ovh_cloud_project_user_s3_credential).
# Run _bootstrap with OVH creds → get access/secret → set these → run _bootstrap again to create bucket.
ENGINE_OVH_S3_REGION=gra
ENGINE_OVH_S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
ENGINE_OVH_S3_ACCESS_KEY=
ENGINE_OVH_S3_SECRET_KEY=
