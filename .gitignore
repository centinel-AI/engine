# Local environment — contains credentials, never commit
.env

# Generated workspace — optional local mirror for manual validation (gitignored)
workspace/*
!workspace/.gitkeep

# Generated provider templates — populated by task generate:<cloud>
providers/aws/*
!providers/aws/.gitkeep
providers/azure/*
!providers/azure/.gitkeep
providers/gcp/*
!providers/gcp/.gitkeep
providers/oci/*
!providers/oci/.gitkeep
providers/ovh/*
!providers/ovh/.gitkeep

# Codegen cache (terraform init + schema dump)
tmp/

# macOS
.DS_Store
