{
  "name": "nsg-app-grauss-web-app",
  "location": "westeurope",
  "resource_group_name": "rg-grauss-web-app",
  "security_rule": [
    {
      "name": "allow-http",
      "priority": 100,
      "direction": "Inbound",
      "access": "Allow",
      "protocol": "Tcp",
      "source_port_range": "*",
      "destination_port_range": "80",
      "source_address_prefix": "*",
      "destination_address_prefix": "*"
    },
    {
      "name": "allow-https",
      "priority": 110,
      "direction": "Inbound",
      "access": "Allow",
      "protocol": "Tcp",
      "source_port_range": "*",
      "destination_port_range": "443",
      "source_address_prefix": "*",
      "destination_address_prefix": "*"
    }
  ],
  "tags": null
}
